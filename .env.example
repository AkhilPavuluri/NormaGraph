# NormaGraph — copy to .env at the repository root. Never commit real secrets.
# See README.md for run modes and scope.

# ========== Core API (FastAPI) ==========
PORT=8000
CORS_ORIGINS=http://localhost:3000

# ========== Google Cloud ==========
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ========== Gemini / Vertex ==========
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=True
# Default aligns with ingestion; override per deployment if needed.
GEMINI_MODEL=models/gemini-2.5-flash

# ========== Vector database ==========
QDRANT_URL=
QDRANT_API_KEY=

# ========== Embeddings ==========
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMENSION=768

# ========== Optional: ingestion (GCS, Document AI) ==========
GCS_BUCKET_NAME=
DOCUMENT_AI_PROCESSOR_ID=

# ========== NormaGraph core (orchestrator / streaming API) ==========
USE_ADK_ROUTER=True
ADK_TIMEOUT_MS=300
OBSERVABILITY_LOG_FILE=normagraph_observability.log

# ========== Frontend (NEXT_PUBLIC_* = exposed to browser) ==========
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GEMINI_API_KEY=
NEXT_PUBLIC_OPENAI_API_KEY=
NEXT_PUBLIC_ANTHROPIC_API_KEY=
